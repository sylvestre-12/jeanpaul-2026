generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int            @id @default(autoincrement())
  phone     String         @unique
  email     String?        @unique
  password  String
  role      Role           @default(USER)
  approved  Boolean        @default(false)
  createdAt DateTime       @default(now())
  name      String?
  lastLogin DateTime?
  profile   String?
  language  Language       @default(EN)
  history   LoginHistory[]
  otps      OTP[]
  results   Result[]
}

model OTP {
  id        Int      @id @default(autoincrement())
  code      String
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
}

model Question {
  id           Int                   @id @default(autoincrement())
  type         QuestionType
  createdAt    DateTime              @default(now())
  deleted      Boolean               @default(false)
  image        String?
  number       Int
  options      Option[]
  images       QuestionImage[]
  translations QuestionTranslation[]
  userAnswers  UserAnswer[]
  tests        Test[]                @relation("TestQuestions")
}

model QuestionTranslation {
  id          Int      @id @default(autoincrement())
  language    Language
  text        String
  questionId  Int
  explanation String?
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, language])
}

model Option {
  id           Int                 @id @default(autoincrement())
  isCorrect    Boolean
  questionId   Int
  question     Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  translations OptionTranslation[]
}

model OptionTranslation {
  id       Int      @id @default(autoincrement())
  language Language
  text     String
  optionId Int
  option   Option   @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, language])
}

model Test {
  id        Int        @id @default(autoincrement())
  title     String
  createdAt DateTime   @default(now())
  duration  Int?
  questions Question[] @relation("TestQuestions")
}

model Result {
  id        Int          @id @default(autoincrement())
  score     Int
  userId    Int
  createdAt DateTime     @default(now())
  total     Int
  user      User         @relation(fields: [userId], references: [id])
  answers   UserAnswer[]
}

model UserAnswer {
  id         Int      @id @default(autoincrement())
  resultId   Int
  questionId Int
  optionId   Int
  question   Question @relation(fields: [questionId], references: [id])
  result     Result   @relation(fields: [resultId], references: [id])
}

model LoginHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model QuestionImage {
  id         Int      @id @default(autoincrement())
  url        String
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  USER
}

enum Language {
  EN
  FR
  RW
}

enum QuestionType {
  NORMAL
  SHORT
}
